# Example only. Do not commit real secrets.
# VITE_CONTACT_EMAIL=hello@example.com

# ── Ticker Signals — Email capture ────────────────────────────────────────────
# Set to the Railway/Render deployed server URL once server is deployed
# VITE_API_BASE_URL=https://preciado-tech-server.railway.app

# ── Stripe Webhook ─────────────────────────────────────────────────────────────
# After deploying server, register webhook at:
# Stripe Dashboard > Developers > Webhooks > Add endpoint
# URL: https://<your-server-url>/api/webhook/stripe
# Events: checkout.session.completed, customer.subscription.deleted

# ── Server Environment Variables (Railway/Render) ───────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY=re_...
# RESEND_FROM_ADDR=signals@preciado-tech.com
# ADMIN_API_KEY=<generate-a-random-string>

# ── Reddit API credentials ─────────────────────────────────────────────────────
# Create app at: https://www.reddit.com/prefs/apps
# REDDIT_CLIENT_ID=your_app_id
# REDDIT_CLIENT_SECRET=your_app_secret
# REDDIT_USERNAME=your_reddit_username
# REDDIT_PASSWORD=your_reddit_password

# ── Twitter/X API credentials ─────────────────────────────────────────────────
# Create dev account at: https://developer.twitter.com/en/apply-for-access
# TWITTER_BEARER_TOKEN=your_bearer_token
# For full posting access, also need:
# TWITTER_API_KEY=...
# TWITTER_API_SECRET=...
# TWITTER_ACCESS_TOKEN=...
# TWITTER_ACCESS_SECRET=...
